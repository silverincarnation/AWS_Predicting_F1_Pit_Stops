# AWS Credentials
# Obtain from: AWS Console → IAM → Your User → Security Credentials
# Required permissions: s3:GetObject, s3:PutObject, s3:ListBucket
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# S3 Bucket
# Must match the bucket name created for this project.
# Overrides the default value in config.yaml.
S3_BUCKET=f1-pitstop-bucket
